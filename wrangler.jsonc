{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fmt-trust-homepage",
  "compatibility_date": "2026-07-11",
  "routes": [
    {
      "pattern": "www.fmttrust.com",
      "custom_domain": true
    },
    {
      "pattern": "fmttrust.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
